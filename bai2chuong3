public class NumberPrinter {
    public static void main(String[] args) {
        for (int i = 1; i <= 5; i++) {
            final int threadNumber = i;
            
            Thread thread = new Thread(() -> {
                for (int j = 1; j <= 10; j++) {
                    System.out.println("Thread-" + threadNumber + ": " + j);
                }
            });
            
            thread.start();
        }
    }
}